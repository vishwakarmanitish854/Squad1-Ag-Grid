# Development environment configuration
# Copy this file to .env.local and update values as needed

# API Configuration
# Use 'false' for development/mock data, 'true' for production API
VITE_USE_MOCK_DATA=true

# API Base URL (only used when VITE_USE_MOCK_DATA is false)
VITE_API_BASE_URL=http://localhost:3000/api

# User Role for testing role-based features
# Options: 'admin' | 'user' | 'viewer'
VITE_USER_ROLE=admin
